# AI Companion 环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改配置

# 应用配置
APP_NAME="AI Companion"
APP_VERSION="1.0.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_companion

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 平台接入配置
# 抖店平台
DOUYIN_APP_KEY=your_douyin_app_key
DOUYIN_APP_SECRET=your_douyin_app_secret
DOUYIN_SHOP_ID=your_douyin_shop_id

# 千帆客服工作台
QIANFAN_APP_KEY=your_qianfan_app_key
QIANFAN_APP_SECRET=your_qianfan_app_secret

# Webhook安全配置
WEBHOOK_SECRET=your_webhook_secret_key

# AI模型配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=

# 向量模型配置
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# 意图识别模型
INTENT_MODEL=bert-base-chinese

# 情感分析模型
EMOTION_MODEL=bert-base-chinese

# 向量数据库配置
VECTOR_STORE_TYPE=chroma

# Chroma配置
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Qdrant配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# 安全配置
SECRET_KEY=your_secret_key_for_jwt_tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS配置
CORS_ORIGINS=["*"]

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE=

# 系统配置
SESSION_TTL=86400
MAX_SESSIONS_PER_USER=10
CONTEXT_TTL=3600
MAX_HISTORY_LENGTH=20